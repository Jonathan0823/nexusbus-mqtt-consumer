# Environment Variables for Telemetry Ingestion Service
# Copy to .env and customize for your environment

# === Required ===

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
POSTGRES_DSN="postgres://postgres:password@localhost:5432/telemetry?sslmode=disable"

# === Optional ===

# MQTT broker password
# MQTT_PASSWORD="your-mqtt-password"

# Redis password
# REDIS_PASSWORD="your-redis-password"

# HTTP server listen address
# HTTP_LISTEN_ADDR=":8080"

# Log level: debug, info, warn, error
LOG_LEVEL="info"

# Service instance ID (useful for multi-instance deployments)
INSTANCE_ID="host01"

# Worker settings
# WORKER_MAX_RETRIES=5
# BATCH_SIZE=500

# Static device profile registry path
# PROFILES_PATH="./profiles.yaml"
