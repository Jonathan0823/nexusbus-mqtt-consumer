# Environment Variables for Telemetry Ingestion Service
# Copy to .env and customize for your environment

# === Service ===
SERVICE_NAME="telemetry-ingestion-service"
INSTANCE_ID="host01"
LOG_LEVEL="info"
HTTP_LISTEN_ADDR=":8080"

# === MQTT ===
# URL examples: tcp://localhost:1883 or ssl://broker.example.com:8883
MQTT_URL="tcp://localhost:1883"
MQTT_CLIENT_ID="telemetry-ingestion-service"
MQTT_TOPIC="telemetry/raw/#"
MQTT_QOS=1
MQTT_CLEAN_SESSION=false
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_SESSION_EXPIRY="168h"

# === Redis ===
# URL examples: redis://localhost:6379 or redis://:password@localhost:6379/0
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_STREAM="telemetry_stream"
REDIS_DEADLETTER_STREAM="telemetry_deadletter_stream"
REDIS_GROUP="telemetry_workers"
REDIS_CONSUMER="host01-worker"
REDIS_READ_COUNT=500
REDIS_BLOCK_TIME="1s"
REDIS_MIN_IDLE_TIME="60s"

# === PostgreSQL ===
POSTGRES_DSN="postgres://postgres:password@localhost:5432/telemetry?sslmode=disable"
POSTGRES_MAX_WRITE_CONNS=10
POSTGRES_MAX_READ_CONNS=5
POSTGRES_BATCH_SIZE=500
POSTGRES_BATCH_TIMEOUT="1s"

# === Worker / Profiles ===
WORKER_MAX_RETRIES=5
WORKER_RETRY_BACKOFF_INITIAL="1s"
WORKER_RETRY_BACKOFF_MAX="60s"
PROFILES_PATH="./profiles.yaml"

# === Ingest Mode ===
# Options: normal (immediate insert) or coalesce (latest-wins per device_id|profile_id)
INGEST_MODE="normal"
# Flush interval for coalesce mode (e.g., 10s, 30s, 1m)
INGEST_FLUSH_INTERVAL="30s"
